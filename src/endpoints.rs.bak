            .map_err(|e| {
                error!("Failed to get transaction: {}", e);
                JsonRpcError::internal_error(format!("Failed to get transaction: {}", e))
            })?;

        let tx_data = tx_data.ok_or_else(|| {
            JsonRpcError::new(-32006, "Transaction not found")
        })?;

        let response = serde_json::json!({
            "hash": format!("0x{}", hex::encode(digest.0)),
            "from": format!("0x{}", tx_data.transaction.sender().to_hex()),
            "blockNumber": format!("0x{:x}", tx_data.effects.block_number),
            "blockHash": format!("0x{}", hex::encode(tx_data.effects.block_hash)),
            "gas": format!("0x{:x}", tx_data.transaction.fuel_budget()),
            "gasPrice": format!("0x{:x}", tx_data.transaction.fuel_price()),
        });

        let elapsed = start.elapsed();
        debug!("Got eth_getTransactionByHash in {:?}", elapsed);

        Ok(response)
    }

    /// Ethereum compatibility: Get transaction receipt
