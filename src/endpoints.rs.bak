    /// Estimate gas for transaction
    pub fn estimate_gas(&self, params: JsonValue) -> Result<JsonValue, JsonRpcError> {
        let start = Instant::now();

        let _request: EstimateGasRequest = serde_json::from_value(params)
            .map_err(|e| JsonRpcError::invalid_params(format!("Invalid parameters: {}", e)))?;

        debug!("Estimating gas");

        // Estimate based on transaction complexity
        let estimated_gas = 21_000u64; // Base transaction cost

        let elapsed = start.elapsed();
        debug!("Estimated gas {} in {:?}", estimated_gas, elapsed);

        Ok(serde_json::json!({
            "gas": estimated_gas.to_string()
        }))
