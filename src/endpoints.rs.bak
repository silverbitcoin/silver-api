    /// Ethereum compatibility: Get block number
    pub fn eth_block_number(&self) -> Result<JsonValue, JsonRpcError> {
        let start = Instant::now();

        debug!("Getting eth_blockNumber");

        let block_number = self
            .transaction_store
            .get_latest_block_number()
            .map_err(|e| {
                error!("Failed to get block number: {}", e);
                JsonRpcError::internal_error(format!("Failed to get block number: {}", e))
            })?;

        let hex_block = format!("0x{:x}", block_number);

        let elapsed = start.elapsed();
        debug!("Got eth_blockNumber {} in {:?}", hex_block, elapsed);

        Ok(JsonValue::String(hex_block))
    }

    /// Ethereum compatibility: Get block by number
    pub fn eth_get_block_by_number(&self, params: JsonValue) -> Result<JsonValue, JsonRpcError> {
        let start = Instant::now();

        let request: EthGetBlockByNumberRequest = serde_json::from_value(params)
            .map_err(|e| JsonRpcError::invalid_params(format!("Invalid parameters: {}", e)))?;

        // Parse hex block number
        let block_number = if request.block_number == "latest" {
            self.transaction_store
                .get_latest_block_number()
                .map_err(|e| JsonRpcError::internal_error(format!("Failed to get block number: {}", e)))?
        } else {
            u64::from_str_radix(request.block_number.trim_start_matches("0x"), 16)
                .map_err(|e| JsonRpcError::invalid_params(format!("Invalid block number: {}", e)))?
        };

        debug!("Getting eth_getBlockByNumber: {}", block_number);

        let block = self
            .transaction_store
            .get_block_by_number(block_number)
            .map_err(|e| {
                error!("Failed to get block: {}", e);
                JsonRpcError::internal_error(format!("Failed to get block: {}", e))
            })?;

        let block = block.ok_or_else(|| {
            JsonRpcError::new(-32005, "Block not found")
        })?;

        let response = serde_json::json!({
            "number": format!("0x{:x}", block.number),
            "hash": format!("0x{}", hex::encode(block.hash)),
            "parentHash": format!("0x{}", hex::encode(block.parent_hash)),
            "timestamp": format!("0x{:x}", block.timestamp),
            "transactions": block.transactions.iter().map(|tx| format!("0x{}", hex::encode(tx))).collect::<Vec<_>>(),
            "miner": format!("0x{}", block.miner.to_hex()),
            "gasUsed": format!("0x{:x}", block.gas_used),
            "gasLimit": format!("0x{:x}", block.gas_limit),
        });

        let elapsed = start.elapsed();
        debug!("Got eth_getBlockByNumber in {:?}", elapsed);

        Ok(response)
    }

    /// Ethereum compatibility: Get transaction by hash
    pub fn eth_get_transaction_by_hash(&self, params: JsonValue) -> Result<JsonValue, JsonRpcError> {
        let start = Instant::now();

        let request: EthGetTransactionByHashRequest = serde_json::from_value(params)
