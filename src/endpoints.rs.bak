            .map_err(|e| {
                error!("Failed to get transaction receipt: {}", e);
                JsonRpcError::internal_error(format!("Failed to get transaction receipt: {}", e))
            })?;

        let tx_data = tx_data.ok_or_else(|| {
            JsonRpcError::new(-32007, "Transaction receipt not found")
        })?;

        let response = serde_json::json!({
            "transactionHash": format!("0x{}", hex::encode(digest.0)),
            "blockNumber": format!("0x{:x}", tx_data.effects.block_number),
            "blockHash": format!("0x{}", hex::encode(tx_data.effects.block_hash)),
            "from": format!("0x{}", tx_data.transaction.sender().to_hex()),
            "gasUsed": format!("0x{:x}", tx_data.effects.fuel_used),
            "status": if tx_data.effects.status == silver_core::ExecutionStatus::Success { "0x1" } else { "0x0" },
        });

        let elapsed = start.elapsed();
        debug!("Got eth_getTransactionReceipt in {:?}", elapsed);

        Ok(response)
    }

